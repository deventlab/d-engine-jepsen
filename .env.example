# d-engine-jepsen Configuration
# IMPORTANT: Copy this file to .env and set S3_BASE_URL with your actual S3 bucket
# Do NOT commit .env to git - it is in .gitignore

# ============ REQUIRED ============
# S3 bucket URL for binary distribution
# NEVER commit this to git or expose internal URLs
# Examples:
#   - Production: https://your-s3-bucket-url.example.com
#   - Internal mirror: https://s3.internal.company.com
#   - Local cache: file:///local/cache
S3_BASE_URL=

# ============ OPTIONAL ============
# Binary names (for cross-platform support)
# Default: linux-amd64
# For macOS: set to darwin-arm64 or darwin-amd64
D_ENGINE_BINARY=three-nodes-embedded-linux-amd64
D_ENGINE_CTL_BINARY=dengine_ctl-linux-amd64

# SSH Keys directory (relative to project root)
SSH_KEYS_PATH=./sshkeys

# Jepsen store directory (test results)
JEP_STORE_PATH=./store

# Test Configuration
TIME_LIMIT=60
ENDPOINTS=http://node1:9081,http://node2:9082,http://node3:9083
